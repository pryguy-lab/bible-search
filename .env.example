PORT=3000
NODE_ENV=production
TRUST_PROXY=1
LOG_REQUESTS=0
ALERT_WINDOW_MS=60000
ALERT_4XX_THRESHOLD=25
ALERT_429_THRESHOLD=10
# Set this to a strong random value in production
ADMIN_API_KEY=replace-with-strong-random-secret
# Optional for multi-instance deployments
# REDIS_URL=redis://127.0.0.1:6379
